# --- GENERAL ---
OUTPUT_DIRECTORY = "@PROJECT_BINARY_DIR@/doc_doxygen/"
INPUT = "@PROJECT_SOURCE_DIR@/src/" "@PROJECT_SOURCE_DIR@/docs"
PROJECT_NAME = @PROJECT_NAME@
RECURSIVE = YES
EXCLUDE_PATTERNS = 
SHOW_USED_FILES = NO
HAVE_DOT = YES
COLLABORATION_GRAPH = YES
INHERITANCE_GRAPH = YES
INCLUDE_GRAPH = YES

# --- HTML ---
GENERATE_HTML = YES
HTML_OUTPUT   = html

# --- PDF (LATEX) ---
GENERATE_LATEX = YES  
LATEX_OUTPUT   = latex
LATEX_BATCHMODE = YES 
USE_PDFLATEX   = YES  
PDF_HYPERLINKS = YES  

# --- SVG ---
DOT_IMAGE_FORMAT = svg
INTERACTIVE_SVG  = YES
